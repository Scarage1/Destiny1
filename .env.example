# ─────────────────────────────────────────────────────────────────────────────
# O2C Graph Intelligence — Environment Variables
# Copy to .env and fill in required values. Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Google Gemini API key (primary LLM provider)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional / Azure-specific ─────────────────────────────────────────────────

# Groq API key — enables automatic Gemini fallback on timeout/rate-limit
GROQ_API_KEY=

# Port to listen on. Azure App Service injects PORT automatically.
PORT=8000

# CORS — comma-separated list of allowed frontend origins
# In production set to your Azure Static Web App URL or custom domain
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database backend (advanced) ───────────────────────────────────────────────

# DB_BACKEND: "sqlite" (default) or "postgres"
DB_BACKEND=sqlite

# Required only when DB_BACKEND=postgres
# Format: postgresql+asyncpg://user:password@host:5432/dbname
POSTGRES_DSN=

# ── LLM tuning ───────────────────────────────────────────────────────────────

# Seconds before an LLM call times out and falls back to heuristic/Groq
LLM_TIMEOUT_SECONDS=20

# Maximum wall-clock time for the entire query pipeline
PIPELINE_TIMEOUT_MS=30000

# ── Cache & circuit breaker ───────────────────────────────────────────────────

# Number of cached query results to hold in memory
CACHE_MAX_SIZE=256

# How many consecutive DB errors before the circuit breaker opens
CIRCUIT_BREAKER_THRESHOLD=3
