# =============================================================================
# O2C Graph Intelligence — Environment Configuration
# Copy this file to .env and fill in your values.
# Only GEMINI_API_KEY is required; all other vars have safe defaults.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Providers (at least one recommended for full query capability)
# ---------------------------------------------------------------------------

# Required for LLM-powered query generation and answer synthesis
GEMINI_API_KEY=

# Optional: Groq fallback provider (used when Gemini is unavailable/errors)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

API_PORT=8000
WEB_PORT=3000

# Comma-separated list of allowed CORS origins (default: localhost only)
# Example for production: CORS_ALLOWED_ORIGINS=https://myapp.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database backend: "sqlite" (default) or "postgres"
DB_BACKEND=sqlite

# ---------------------------------------------------------------------------
# O2C Runtime Tuning (all optional — defaults shown)
# ---------------------------------------------------------------------------

# Total pipeline wall-clock timeout (milliseconds)
O2C_PIPELINE_TIMEOUT_MS=8000

# LLM call timeout (seconds)
O2C_LLM_TIMEOUT_SECONDS=20.0

# Per-stage time budgets (milliseconds)
O2C_STAGE_BUDGET_PLANNER_MS=700
O2C_STAGE_BUDGET_GUARD_MS=120
O2C_STAGE_BUDGET_VALIDATOR_MS=120
O2C_STAGE_BUDGET_QUERY_AGENT_MS=300
O2C_STAGE_BUDGET_EXECUTION_MS=2500
O2C_STAGE_BUDGET_VERIFICATION_MS=300
O2C_STAGE_BUDGET_RESPONSE_MS=2200

# Force deterministic SQL templates only — never fall back to LLM-generated SQL
O2C_STRICT_DETERMINISTIC=false

# SQL result cache settings
O2C_SQL_CACHE_TTL_SECONDS=30
O2C_SQL_CACHE_MAX_ENTRIES=256

# SQL execution retry count on failure
O2C_SQL_EXEC_RETRIES=1

# Circuit breaker: open after this many consecutive failures
O2C_EXEC_CB_FAILURE_THRESHOLD=3

# Circuit breaker: stay open for this many seconds before half-open retry
O2C_EXEC_CB_OPEN_SECONDS=20

# Conversation memory capacity (max concurrent sessions)
O2C_MEMORY_MAX_CONVERSATIONS=2000

# Observability trace retention
O2C_OBS_RECENT_TRACES=500
O2C_OBS_EVENTS_PER_TRACE=50
O2C_OBS_METRICS_MAX_EVENTS_SCAN=10000
