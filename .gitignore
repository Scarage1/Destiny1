# Data artifacts
# Allow SAP source data files in git so they are included in Docker builds.
# The generated SQLite database remains gitignored.
data/raw/*
!data/raw/.gitkeep
!data/raw/sap-o2c-data/
!data/raw/sap-o2c-data/**
data/*.db
data/*.db-wal
data/*.db-shm
o2c.db

# Logs
logs/
tmp/

# Secrets
*.pem
*.key
secrets.*
